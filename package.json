  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "object-inspect": "^1.13.0",
    "uuid": "^9.0.0",
    "graphql": "^16.8.0",
    "node-forge": "^1.3.1",
    "lodash": "^4.17.21"
  }
}
